{
  "name": "@kickbacks/auction-engine",
  "version": "0.1.0",
  "description": "Single-slot sealed-bid second-price (Vickrey) auction engine for the Kickbacks ad backend.",
  "license": "MIT",
  "author": "Thomas Rossi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThomasRossi/vickrey-auction-engine.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/memory": {
      "types": "./dist/adapters/memory/index.d.ts",
      "import": "./dist/adapters/memory/index.js"
    },
    "./adapters/redis": {
      "types": "./dist/adapters/redis/index.d.ts",
      "import": "./dist/adapters/redis/index.js"
    },
    "./adapters/postgres": {
      "types": "./dist/adapters/postgres/index.d.ts",
      "import": "./dist/adapters/postgres/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.30.0",
    "ioredis": "^5.4.0",
    "pg": "^8.12.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": { "optional": true },
    "ioredis": { "optional": true },
    "pg": { "optional": true }
  }
}
